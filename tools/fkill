#!/bin/sh
#
# Interactive process killer using fzf.
# Shows PID, user, CPU%, memory%, port(s), and full command line.
# Works on macOS and Linux (Ubuntu).

set -e

# ============================================================================
# Usage
# ============================================================================
usage() {
  echo "Usage: fkill [OPTIONS] [QUERY]"
  echo ""
  echo "Interactively select and kill processes using fzf."
  echo ""
  echo "OPTIONS"
  echo "  -a, --all         Show all users' processes (default: own only)"
  echo "  -9, --force       Send SIGKILL instead of SIGTERM"
  echo "  -s, --signal SIG  Signal to send (default: TERM)"
  echo "  -h, --help        Show this help message"
  echo ""
  echo "ARGUMENTS"
  echo "  QUERY              Initial fzf filter query"
  echo ""
  echo "KEYBINDINGS (in fzf)"
  echo "  tab                Toggle selection"
  echo "  ctrl-a             Select all"
  echo "  ctrl-r             Reload process list"
  echo "  enter              Kill selected processes"
}

# ============================================================================
# Defaults
# ============================================================================
SIGNAL="TERM"
QUERY=""
SHOW_ALL=false

# ============================================================================
# Parse arguments
# ============================================================================
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --list)
      # Internal: used by fzf ctrl-r reload binding.
      # Deferred until list_processes is defined.
      LIST_ONLY=true
      shift
      ;;
    -a|--all)
      SHOW_ALL=true
      shift
      ;;
    -9|--force)
      SIGNAL="KILL"
      shift
      ;;
    -s|--signal)
      if [ -z "$2" ]; then
        echo "Error: --signal requires an argument" >&2
        exit 1
      fi
      SIGNAL="$2"
      shift 2
      ;;
    -*)
      echo "Error: unknown option '$1'" >&2
      echo "Run 'fkill --help' for usage." >&2
      exit 1
      ;;
    *)
      QUERY="$1"
      shift
      ;;
  esac
done

# ============================================================================
# Check dependencies
# ============================================================================
if ! command -v fzf >/dev/null 2>&1; then
  echo "Error: fzf is not installed" >&2
  exit 1
fi

# ============================================================================
# Build process list with port info
# ============================================================================
# Outputs: PID USER %CPU %MEM PORTS COMMAND
# Merges ps output with lsof port data.
list_processes() {
  # Write port info to a temp file to avoid shell quoting issues with newlines.
  port_file=$(mktemp)
  trap "rm -f '$port_file'" EXIT

  # Collect listening ports: PID -> comma-separated ports.
  # lsof may need sudo for other users' processes; best-effort without.
  lsof -i -P -n 2>/dev/null \
    | awk 'NR>1 && /\(LISTEN\)/ {
        name = $(NF-1)
        split(name, a, ":")
        port = a[length(a)]
        key = $2
        if (!(key in seen) || index(seen[key], port) == 0) {
          if (key in seen) seen[key] = seen[key] "," port
          else seen[key] = port
        }
      }
      END { for (k in seen) print k, seen[k] }' > "$port_file"

  # ps output — BSD (macOS) and procps (Linux) both support this format.
  cur_user=$(id -un)
  ps ax -o pid=,user=,pcpu=,pmem=,command= | awk -v pf="$port_file" -v show_all="$SHOW_ALL" -v me="$cur_user" '
    BEGIN {
      while ((getline line < pf) > 0) {
        split(line, kv, " ")
        pmap[kv[1]] = kv[2]
      }
      close(pf)
      printf "%-7s %-20s %5s %5s %-14s %s\n", "PID", "USER", "%CPU", "%MEM", "PORTS", "COMMAND"
    }
    {
      pid = $1 + 0
      if (pid == 0) next

      user = $2
      if (show_all != "true" && user != me) next

      cpu  = $3
      mem  = $4

      cmd = ""
      for (i = 5; i <= NF; i++) cmd = cmd (i > 5 ? " " : "") $i

      p = (pid in pmap) ? pmap[pid] : "-"
      printf "%-7d %-20s %5s %5s %-14s %s\n", pid, user, cpu, mem, p, cmd
    }
  '

  rm -f "$port_file"
}

# Handle --list (internal, for fzf reload)
if [ "${LIST_ONLY:-}" = true ]; then
  list_processes
  exit 0
fi

# ============================================================================
# Run fzf
# ============================================================================
# Use a reload binding so the user can refresh the process list.
SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
RELOAD_CMD="$SELF --list"
if [ "$SHOW_ALL" = true ]; then
  RELOAD_CMD="$SELF --list -a"
fi

selected=$(list_processes | fzf \
  --multi \
  --header-lines=1 \
  --query="$QUERY" \
  --prompt="kill ($SIGNAL)> " \
  --bind="ctrl-r:reload($RELOAD_CMD)" \
  --bind="ctrl-a:select-all" \
  --preview='pid={1}; echo "=== Process $pid ==="; ps -p $pid -o pid,ppid,user,stat,%cpu,%mem,start,time,command= 2>/dev/null || echo "Process not found"; echo; echo "=== Open files (first 20) ==="; lsof -p $pid 2>/dev/null | head -20 || echo "No info"' \
  --preview-window=down:40%:wrap \
) || exit 0

# ============================================================================
# Kill selected processes
# ============================================================================
echo "$selected" | while IFS= read -r line; do
  pid=$(echo "$line" | awk '{print $1}')
  cmd=$(echo "$line" | awk '{for(i=6;i<=NF;i++) printf "%s ", $i; print ""}')

  if kill -s "$SIGNAL" "$pid" 2>/dev/null; then
    echo "Killed $pid (SIG$SIGNAL): $cmd"
  else
    echo "Failed to kill $pid — try with sudo or -9" >&2
  fi
done
