#!/usr/bin/env bash
set -euo pipefail

PROGRAM=${0##*/}

usage() {
  cat <<EOF
Usage: $PROGRAM [options] [gpu-query]

Find reservable x86_64 Colossus machines, sort them by availability, select one
with fzf, and open the lease scheduler filtered to that machine.

Options:
  --no-open  Print the scheduler URL without opening a browser
  -h, --help Show this help

Environment:
  COLOSSUS_GPU_QUERY       Default GPU query when no argument is supplied
  COLOSSUS_ARCH            CPU architecture filter (default: x86_64)
  COLOSSUS_MAX_RESULTS     Maximum resources to scan, 1-500 (default: 500)
  COLOSSUS_LEASE_JOBS      Parallel lease lookups (default: 8)
  COLOSSUS_WEB_BASE_URL    Web UI origin (default: https://colossus.nvidia.com)
  COLOSSUS_WEB_PATH        Web UI scheduler path (default: /baremetal/schedule)
  COLOSSUS_BROWSER_CMD     Browser opener executable (default: open/xdg-open)
  COLOSSUS_NO_OPEN         Set to 1 for the same behavior as --no-open

Examples:
  $PROGRAM
  $PROGRAM h100
  COLOSSUS_GPU_QUERY=blackwell $PROGRAM
  COLOSSUS_LEASE_JOBS=12 $PROGRAM b200
EOF
}

die() {
  printf '%s: %s\n' "$PROGRAM" "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

is_positive_integer() {
  case $1 in
    '' | *[!0-9]*) return 1 ;;
    *) (($1 > 0)) ;;
  esac
}

fetch_lease_end() {
  local lease_id=$1
  local resource_id=$2
  local end_time

  case $resource_id in
    '' | *[!A-Za-z0-9._-]*) return 0 ;;
  esac

  end_time=$(
    colossus bm lease list --lease-id "$lease_id" --json 2>/dev/null |
      jq -er '.[0].lease_details.endTime // empty' 2>/dev/null
  ) || return 0

  [[ -n $end_time ]] || return 0
  printf '%s\n' "$end_time" >"$COLOSSUS_SCAN_DIR/$resource_id.end"
}

# Internal worker used by xargs for bounded parallel lease lookups.
if [[ ${1:-} == __fetch-lease-end ]]; then
  [[ $# -eq 3 && -n ${COLOSSUS_SCAN_DIR:-} ]] || exit 2
  fetch_lease_end "$2" "$3"
  exit 0
fi

gpu_query=
gpu_query_from_arg=0
no_open=${COLOSSUS_NO_OPEN:-0}

while (($# > 0)); do
  case $1 in
    -h | --help)
      usage
      exit 0
      ;;
    --no-open)
      no_open=1
      ;;
    --*)
      die "unknown option: $1"
      ;;
    *)
      ((gpu_query_from_arg == 0)) || die "provide only one GPU query"
      gpu_query=$1
      gpu_query_from_arg=1
      ;;
  esac
  shift
done

if ((gpu_query_from_arg == 0)); then
  gpu_query=${COLOSSUS_GPU_QUERY:-}
fi

if [[ -z $gpu_query ]]; then
  [[ -t 0 ]] || die "GPU query required when stdin is not a terminal"
  printf 'GPU (a100, h100, blackwell, b200, h200, ...): ' >&2
  IFS= read -r gpu_query
fi
[[ -n $gpu_query ]] || die "GPU query cannot be empty"

arch=${COLOSSUS_ARCH:-x86_64}
max_results=${COLOSSUS_MAX_RESULTS:-500}
lease_jobs=${COLOSSUS_LEASE_JOBS:-8}
web_base=${COLOSSUS_WEB_BASE_URL:-https://colossus.nvidia.com}
web_path=${COLOSSUS_WEB_PATH:-/baremetal/schedule}

is_positive_integer "$max_results" || die "COLOSSUS_MAX_RESULTS must be a positive integer"
((max_results <= 500)) || die "COLOSSUS_MAX_RESULTS cannot exceed Colossus's 500-item page limit"
is_positive_integer "$lease_jobs" || die "COLOSSUS_LEASE_JOBS must be a positive integer"
[[ $no_open == 0 || $no_open == 1 ]] || die "COLOSSUS_NO_OPEN must be 0 or 1"

require_command colossus
require_command jq
require_command fzf
require_command sort
require_command xargs

whoami_output=$(colossus whoami 2>&1 || true)
case $whoami_output in
  '' | *'Current User: None'* | *'not logged in'* | *'Not logged in'*)
    printf 'Colossus authentication is required; starting login...\n' >&2
    colossus login || die "login failed; run 'colossus login' and retry"
    whoami_output=$(colossus whoami 2>&1 || true)
    case $whoami_output in
      '' | *'Current User: None'* | *'not logged in'* | *'Not logged in'*)
        die "login did not complete; run 'colossus login' and retry"
        ;;
    esac
    ;;
esac

scan_dir=$(mktemp -d "${TMPDIR:-/tmp}/colossus-gpu-lease.XXXXXX")
trap 'rm -rf "$scan_dir"' EXIT HUP INT TERM
export COLOSSUS_SCAN_DIR=$scan_dir

resources_json=$scan_dir/resources.json
candidates_tsv=$scan_dir/candidates.tsv
lease_ids_tsv=$scan_dir/lease-ids.tsv
rows_tsv=$scan_dir/rows.tsv

printf 'Searching Colossus for reservable %s machines matching %q...\n' "$arch" "$gpu_query" >&2
if ! colossus bm resource list \
  --filters "cpus.sockets.arch=$arch" \
  --search "$gpu_query" \
  --authorized-to-reserve \
  --page-size "$max_results" \
  --json >"$resources_json"; then
  die "resource search failed"
fi

jq -e 'type == "array"' "$resources_json" >/dev/null || die "Colossus returned unexpected resource data"

jq -r '
  def text($fallback):
    if . == null or . == "" then $fallback
    else tostring | gsub("[\\t\\r\\n]"; " ")
    end;
  .[]
  | (.status // "" | ascii_downcase) as $status
  | select($status == "available" or $status == "reserved")
  | ([.gpus[]? |
        [.retailProductName?, .architecture?, .chipName?, .type?]
        | map(select(. != null and . != "") | tostring)
        | unique
        | join(" / ")]
      | unique) as $gpu_models
  | ([.gpus[]?] | length) as $gpu_count
  | [
      (.id | text("-")),
      (.name | text("-")),
      $status,
      (.poolName | text("-")),
      (.machineType | text("-")),
      (.leaseId | text("-")),
      (.leasee | text("-")),
      (if $gpu_count == 0 then "unknown GPU"
       else ($gpu_count | tostring) + "x " + ($gpu_models | join("; "))
       end)
    ]
  | @tsv
' "$resources_json" >"$candidates_tsv"

candidate_count=$(wc -l <"$candidates_tsv" | tr -d ' ')
((candidate_count > 0)) || die "no available or reserved $arch machines matched '$gpu_query'"

awk -F '\t' '$3 == "reserved" && $6 != "-" { print $6 "\t" $1 }' "$candidates_tsv" >"$lease_ids_tsv"
reserved_count=$(wc -l <"$lease_ids_tsv" | tr -d ' ')

if ((reserved_count > 0)); then
  printf 'Found %s candidate(s); resolving %s lease end time(s) with %s worker(s)...\n' \
    "$candidate_count" "$reserved_count" "$lease_jobs" >&2
  xargs -P "$lease_jobs" -n 2 "$0" __fetch-lease-end <"$lease_ids_tsv"
else
  printf 'Found %s candidate(s), all available now.\n' "$candidate_count" >&2
fi

while IFS=$'\t' read -r resource_id name status pool machine_type lease_id leasee gpu_label; do
  case $status in
    available)
      sort_key='0000-00-00 00:00:00 +0000'
      availability='NOW'
      ;;
    reserved)
      if [[ -f $scan_dir/$resource_id.end ]]; then
        end_time=$(<"$scan_dir/$resource_id.end")
        sort_key=$end_time
        availability="lease ends $end_time"
      else
        sort_key='9999-12-31 23:59:59 +9999'
        availability='lease end unknown'
      fi
      ;;
    *)
      continue
      ;;
  esac

  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$sort_key" "$availability" "$name" "$gpu_label" "$pool" \
    "$machine_type" "$status" "$leasee" "$resource_id" >>"$rows_tsv"
done <"$candidates_tsv"

selected=$(
  LC_ALL=C sort -t $'\t' -k1,1 "$rows_tsv" |
    fzf \
      --delimiter=$'\t' \
      --with-nth=2..8 \
      --no-sort \
      --layout=reverse \
      --height=90% \
      --border \
      --prompt="Colossus $gpu_query > " \
      --header=$'AVAILABLE\tMACHINE\tGPU\tPOOL\tTYPE\tSTATUS\tCURRENT LEASEE'
) || exit 0

IFS=$'\t' read -r _ availability name _ _ _ _ _ resource_id <<<"$selected"
[[ -n $resource_id && -n $name ]] || die "could not read the selected resource"

# Colossus persists the scheduler search in its `search` URL parameter using
# a marked object. `query=<machine>` is sufficient to open a one-machine view.
search_state=$(jq -rn --arg value "query=$name" '$value | @uri')
web_base=${web_base%/}
[[ $web_path == /* ]] || web_path=/$web_path
url="$web_base$web_path?search=$search_state"

printf 'Selected %s (%s, %s)\n%s\n' "$name" "$availability" "$resource_id" "$url" >&2

if [[ $no_open == 1 ]]; then
  printf '%s\n' "$url"
  exit 0
fi

if [[ -n ${COLOSSUS_BROWSER_CMD:-} ]]; then
  "$COLOSSUS_BROWSER_CMD" "$url"
elif command -v open >/dev/null 2>&1; then
  open "$url"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url"
else
  printf '%s: no browser opener found; open this URL manually:\n%s\n' "$PROGRAM" "$url" >&2
fi
